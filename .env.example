# API Configuration
VITE_API_BASE_URL=http://localhost:5000

# AWS Cognito Configuration
VITE_AWS_REGION=us-east-1
VITE_AWS_COGNITO_USER_POOL_ID=your-user-pool-id
VITE_AWS_COGNITO_CLIENT_ID=your-client-id
VITE_AWS_COGNITO_IDENTITY_POOL_ID=your-identity-pool-id

# OAuth Configuration (for Google Sign In)
VITE_AWS_COGNITO_DOMAIN=your-cognito-domain.auth.us-east-1.amazoncognito.com
VITE_REDIRECT_SIGN_IN=http://localhost:5173/
VITE_REDIRECT_SIGN_OUT=http://localhost:5173/
